{
  "name": "windows-app-for-linux",
  "productName": "OpenAVDClient",
  "version": "1.0.0",
  "description": "Open Azure Virtual Desktop Client - an unofficial standalone Electron client for Azure Virtual Desktop web access",
  "main": "src/main.js",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "start": "electron src/main.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --arm64",
    "build:mac:dir": "electron-builder --mac dir --arm64",
    "lint": "./scripts/lint.sh",
    "test": "node --test tests/*.test.js",
    "verify": "bun run lint && bun run test && bun audit",
    "build:snap": "./scripts/build-snap.sh",
    "build:flatpak": "flatpak-builder build/flatpak-build src/windows-app-for-linux.desktop.yml --force-clean",
    "install:flatpak": "flatpak-builder --user --install --force-clean build/flatpak-build src/windows-app-for-linux.desktop.yml",
    "clean": "rm -rf build/ .snapcraft/ *.snap",
    "clean:snap": "rm -rf build/snap/",
    "clean:flatpak": "rm -rf build/flatpak-build/"
  },
  "keywords": [
    "electron",
    "windows-cloud",
    "remote-desktop"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "41.5.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "dev.openavdclient.app",
    "productName": "OpenAVDClient",
    "directories": {
      "output": "build/dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "src/windows-app-for-linux",
      "notarize": false,
      "extendInfo": {
        "NSCameraUsageDescription": "OpenAVDClient needs camera access when a remote desktop session requests video input.",
        "NSMicrophoneUsageDescription": "OpenAVDClient needs microphone access when a remote desktop session requests audio input."
      }
    },
    "dmg": {
      "sign": true
    }
  }
}

